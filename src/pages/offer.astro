---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CockpitPanel from "../components/CockpitPanel.astro";
import OfferGrid from "../components/OfferGrid.astro";
import { posts, services } from "../lib/siteModel.js";

const proofItems = [
  { label: "内容", value: `${posts.length} 篇公开笔记作为信任样本` },
  { label: "方法", value: "从 Obsidian 到 Vercel 的完整发布链路" },
  { label: "方向", value: "AI 编程 / 复盘 / 项目交付" }
];
---

<BaseLayout title="课程陪跑 · Ury 的知识花园" description="AI 编程、项目复盘与 Obsidian 知识库搭建陪跑服务。">
  <Header />
  <main>
    <section class="site-shell hero offer-hero">
      <div>
        <h1>不是再收藏一篇教程，而是把项目推进到下一步。</h1>
        <p class="hero-lede">公开博客负责沉淀知识，付费陪跑负责把你的目标拆成任务、节奏和交付物。适合正在学习 AI 编程、搭建个人知识库、推进毕业设计或独立项目的人。</p>
        <div class="hero-actions">
          <a class="button primary" href="mailto:hello@example.com?subject=课程陪跑咨询">预约咨询</a>
          <a class="button" href="/archive/">先看公开内容</a>
        </div>
      </div>
      <CockpitPanel title="公开资产" eyebrow="proof" items={proofItems} />
    </section>
    <section class="site-shell section">
      <OfferGrid services={services} ctaLabel="咨询这个服务" ctaHref="mailto:hello@example.com" />
    </section>
  </main>
  <Footer />
</BaseLayout>
