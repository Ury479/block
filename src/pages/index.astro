---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PostRow from "../components/PostRow.astro";
import SyncFlow from "../components/SyncFlow.astro";
import SectionHead from "../components/SectionHead.astro";
import ProofGrid from "../components/ProofGrid.astro";
import CockpitPanel from "../components/CockpitPanel.astro";
import OfferGrid from "../components/OfferGrid.astro";
import TypeRail from "../components/TypeRail.astro";
import CollectionGrid from "../components/CollectionGrid.astro";
import {
  getCollections,
  getProofItems,
  getRecentPosts,
  getTypeCounts,
  manifest,
  posts,
  services,
  topics
} from "../lib/siteModel.js";

const recent = getRecentPosts(5);
const typeCounts = getTypeCounts();
const collections = getCollections();
const proofItems = getProofItems();
const cockpitItems = [
  { label: "路线", value: "AI 编程 · 项目上线 · 复盘系统" },
  { label: "内容", value: `${posts.length} 篇从 Obsidian 同步的公开笔记` },
  { label: "转化", value: "免费知识库 + 付费陪跑服务" }
];
---

<BaseLayout>
  <Header />
  <main>
    <section class="site-shell hero">
      <div>
        <h1>把 {posts.length}+ 篇学习笔记，变成可复用的成长系统。</h1>
        <p class="hero-lede">这里公开沉淀 AI 编程、项目复盘、成功日记和课程笔记。你可以免费阅读，也可以进入付费陪跑，把知识转成真实项目进度。</p>
        <div class="hero-actions">
          <a class="button primary" href="#latest">开始阅读</a>
          <a class="button" href="/offer/">了解付费陪跑</a>
        </div>
        <ProofGrid items={proofItems} />
      </div>
      <CockpitPanel
        title="学习驾驶舱"
        eyebrow="Now"
        items={cockpitItems}
        cta={recent[0] && { href: recent[0].url, label: `读最新：${recent[0].title}` }}
      />
    </section>

    <section class="site-shell section offer-section">
      <SectionHead
        title="把阅读变成结果"
        kicker="参考 Josh Comeau 的课程转化方式：先用高质量公开内容建立信任，再提供清晰、具体、可购买的下一步。"
      />
      <OfferGrid services={services} compact />
    </section>

    <section class="site-shell section">
      <SectionHead
        title="三种内容形态"
        kicker="参照 Mix Space 的内容模型，把正式文章、短记录与碎片思考分开，让首页不再只有单一列表。"
      />
      <TypeRail items={typeCounts} />
    </section>

    <section class="site-shell section">
      <SectionHead
        title="精选合集"
        kicker="这次已把你指定的三个 Obsidian 目录同步成公开博客内容，并按来源聚合成入口。"
      />
      <CollectionGrid collections={collections} />
    </section>

    <section id="latest" class="site-shell section">
      <SectionHead title="最近更新" kicker="默认只展示已公开标记或指定同步的 Obsidian 文档。" />
      {recent.length ? (
        <div class="post-list">
          {recent.map((post) => <PostRow post={post} />)}
        </div>
      ) : (
        <div class="empty-state">
          还没有公开文章。给 Obsidian 笔记添加 <code>publish: true</code>，或运行 <code>npm run sync -- --file "笔记绝对路径"</code> 后，这里会自动出现内容。
        </div>
      )}
    </section>

    <section class="site-shell section">
      <SectionHead title="知识地图" kicker="主题不是硬分类，而是从笔记路径、标签与 frontmatter 中自然长出来的索引。" />
      <div class="garden-grid">
        <div class="panel topic-map">
          {topics.length ? topics.map((topic) => (
            <a class="topic-chip" href={`/archive/?topic=${encodeURIComponent(topic.name)}`}>{topic.name}<span>{topic.count}</span></a>
          )) : (
            <span class="section-kicker">等待首次公开同步后生成主题。</span>
          )}
        </div>
        <SyncFlow manifest={manifest} />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
