---
import "../styles/global.css";
import translateScriptUrl from "i18n-jsautotranslate/index.js?url";

const {
  title = "Ury 的知识花园",
  description = "把 400+ 篇学习笔记，变成可阅读、可复用、可陪跑的成长系统。"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <!-- 无 FOUC 主题 + 季节初始化：首帧 paint 前设置 data-theme（明暗）与 data-season（四季皮肤）。
         明暗：localStorage.theme，无则跟系统 prefers-color-scheme。
         季节：localStorage.season，无则按当前月份自动（3-5春/6-8夏/9-11秋/12-2冬）；
               用户手动选过之后（season-set=1）尊重其选择，不再自动覆盖。 -->
    <script is:inline>
      (() => {
        const doc = document.documentElement;
        try {
          // 明暗
          const savedTheme = localStorage.getItem("theme");
          const theme = savedTheme || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          doc.dataset.theme = theme;
          // 季节
          const savedSeason = localStorage.getItem("season");
          const seasonSet = localStorage.getItem("season-set") === "1";
          let season = savedSeason;
          if (!season) {
            const m = new Date().getMonth() + 1;
            season = (m >= 3 && m <= 5) ? "spring" : (m >= 6 && m <= 8) ? "summer" : (m >= 9 && m <= 11) ? "autumn" : "winter";
          }
          doc.dataset.season = season;
          // theme-color 跟随明暗（季节不改 paper 明度，故只按 light/dark 切换浏览器顶栏色）
          const tc = document.querySelector('meta[name="theme-color"]');
          if (tc) tc.setAttribute("content", theme === "dark" ? "#1a1d16" : "#f8f3ea");
          // 未手动设过季节时，标记为自动（供 SeasonSwitcher 显示「自动」态）
          if (!seasonSet) doc.dataset.seasonAuto = "1";
        } catch {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#f8f3ea" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <slot />
    <script is:inline src={translateScriptUrl}></script>
    <script is:inline>
      (() => {
        const initTranslate = () => {
          if (!window.translate) return;
          const translate = window.translate;

          translate.language.setLocal("chinese_simplified");
          translate.language.translateLanguagesRange = ["chinese_simplified", "english"];
          translate.selectLanguageTag.languages = "chinese_simplified,english";
          translate.selectLanguageTag.documentId = "translate";
          translate.service.use("client.edge");
          translate.ignore.tag.push("pre", "code", "kbd", "samp", "script", "style", "textarea", "input");
          translate.ignore.class.push("no-translate", null);
          translate.ignore.class.push("astro-code", null);
          translate.listener.start();
          translate.execute();
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initTranslate, { once: true });
        } else {
          initTranslate();
        }
      })();
    </script>
  </body>
</html>
