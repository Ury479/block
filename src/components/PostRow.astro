---
const { post } = Astro.props;
const date = new Intl.DateTimeFormat("zh-CN", { year: "numeric", month: "2-digit", day: "2-digit" }).format(new Date(post.date));
---

<a class="post-row" href={post.url} data-type={post.type} data-topic={post.topic} data-title={post.title}>
  <span class="post-date">{date}</span>
  <span>
    <h3>{post.title}</h3>
    <p>{post.excerpt || "这篇文章来自 Obsidian 同步副本。"}</p>
  </span>
  <span class="post-meta">{post.type} · {post.readingMinutes || 1} 分钟</span>
</a>
