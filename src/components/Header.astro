---
import SeasonSwitcher from "./SeasonSwitcher.astro";
const current = Astro.url.pathname;
const nav = [
  ["/", "首页"],
  ["/archive/", "文稿"],
  ["/offer/", "课程陪跑"],
  ["/now/", "现在"],
  ["/garden/", "知识地图"],
  ["/sync/", "同步"]
];
---

<header class="site-header">
  <div class="site-shell header-inner">
    <a class="brand" href="/">
      <span class="brand-mark">雨</span>
      <span>
        <span class="brand-title">Ury 的知识花园</span>
        <span class="brand-subtitle">Obsidian to Blog</span>
      </span>
    </a>
    <nav class="site-nav" aria-label="主导航">
      {nav.map(([href, label]) => (
        <a href={href} aria-current={current === href ? "page" : undefined}>{label}</a>
      ))}
      <a href="/rss.xml">RSS</a>
      <div id="translate" class="translate-control no-translate" aria-label="中英文翻译"></div>
      <SeasonSwitcher />
      <button id="theme-toggle" class="theme-toggle no-translate" type="button" aria-label="切换深浅色主题" title="切换深浅色"></button>
    </nav>
  </div>
</header>
<script>
  // 主题切换：读写 localStorage，同步 data-theme（无 FOUC 初始脚本在 BaseLayout 已设好）。
  const btn = document.querySelector("#theme-toggle");
  const sync = () => {
    const dark = document.documentElement.dataset.theme === "dark";
    btn && (btn.textContent = dark ? "☀" : "☾");
    btn && btn.setAttribute("aria-pressed", String(dark));
  };
  sync();
  btn?.addEventListener("click", () => {
    const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    try { localStorage.setItem("theme", next); } catch {}
    sync();
  });
</script>
