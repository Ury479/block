{
  "name": "ury-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "astro build",
    "build:local": "npm run sync:publish-roots && astro build",
    "preview": "astro preview --host 127.0.0.1",
    "sync": "node scripts/sync-obsidian.mjs",
    "sync:safe": "node scripts/sync-obsidian.mjs --safe",
    "sync:publish-roots": "node scripts/sync-obsidian.mjs --publish-roots",
    "sync:file": "node scripts/sync-obsidian.mjs --file",
    "test": "vitest run",
    "test:e2e": "node scripts/qa-smoke.mjs",
    "test:all": "vitest run && npm run build && node scripts/qa-smoke.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.3",
    "fast-glob": "^3.3.3",
    "i18n-jsautotranslate": "^4.0.0",
    "reading-time": "^1.5.0",
    "sharp": "^0.34.3",
    "yaml": "^2.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
